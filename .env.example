# ============================================================
# Copy this file to `.env` and fill in the values you need.
#   cp .env.example .env      (macOS/Linux)
#   Copy-Item .env.example .env   (PowerShell)
# The real `.env` is git-ignored — never commit your keys.
# ============================================================

# ---- LLM (needed for real recommendations; else the app uses an offline mock) ----
# Get a free key at https://console.groq.com  (hosts Gemma — the project default)
GROQ_API_KEY=
# Optional alternatives (only if you switch ADVISOR_LLM_PROVIDER):
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ---- Advisor overrides (optional; sensible defaults in advisor/config.py) ----
# ADVISOR_LLM_PROVIDER=groq          # groq | anthropic | gemini | mock
# ADVISOR_LLM_MODEL=gemma2-9b-it
# ADVISOR_DEVICE=cpu                 # cpu is fine for serving; cuda for training
# ADVISOR_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Data re-pull keys (ONLY if rebuilding the dataset from scratch) ----
# CPCB ground truth is already recovered and committed, so you usually don't need this.
OPENAQ_API_KEY=
# CDSAPI_KEY=
# FIRMS_MAP_KEY=
# EARTHDATA_TOKEN=
